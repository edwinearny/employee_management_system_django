{
  "info": {
    "name": "Employee Management System",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://127.0.0.1:8000" },
    { "key": "access_token", "value": "" },
    { "key": "refresh_token", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/accounts/api/register/",
            "body": {
              "mode": "raw",
              "raw": "{\"username\": \"testuser\", \"email\": \"test@example.com\", \"password\": \"test1234\"}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var res = pm.response.json();",
                  "pm.collectionVariables.set('access_token', res.access);",
                  "pm.collectionVariables.set('refresh_token', res.refresh);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/accounts/api/login/",
            "body": {
              "mode": "raw",
              "raw": "{\"username\": \"testuser\", \"password\": \"test1234\"}"
            }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/accounts/api/token/refresh/",
            "body": {
              "mode": "raw",
              "raw": "{\"refresh\": \"{{refresh_token}}\"}"
            }
          }
        },
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/accounts/api/profile/"
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/accounts/api/profile/",
            "body": {
              "mode": "raw",
              "raw": "{\"phone\": \"9876543210\"}"
            }
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/accounts/api/change-password/",
            "body": {
              "mode": "raw",
              "raw": "{\"old_password\": \"test1234\", \"new_password\": \"newpass1234\"}"
            }
          }
        }
      ]
    },
    {
      "name": "Forms",
      "item": [
        {
          "name": "List Forms",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/api/forms/"
          }
        },
        {
          "name": "Create Form",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/api/forms/",
            "body": {
              "mode": "raw",
              "raw": "{\"name\": \"HR Form\", \"fields\": [{\"label\": \"Full Name\", \"field_type\": \"text\", \"order\": 0}, {\"label\": \"Age\", \"field_type\": \"number\", \"order\": 1}, {\"label\": \"Join Date\", \"field_type\": \"date\", \"order\": 2}]}"
            }
          }
        },
        {
          "name": "Get Form",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/api/forms/1/"
          }
        },
        {
          "name": "Update Form",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/api/forms/1/",
            "body": {
              "mode": "raw",
              "raw": "{\"name\": \"Updated HR Form\", \"fields\": [{\"label\": \"Full Name\", \"field_type\": \"text\", \"order\": 0}, {\"label\": \"Department\", \"field_type\": \"text\", \"order\": 1}]}"
            }
          }
        },
        {
          "name": "Delete Form",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/api/forms/1/"
          }
        }
      ]
    },
    {
      "name": "Employees",
      "item": [
        {
          "name": "List Employees",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/api/employees/"
          }
        },
        {
          "name": "Search Employees",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": {
              "raw": "{{base_url}}/api/employees/?q=john",
              "query": [{ "key": "q", "value": "john" }]
            }
          }
        },
        {
          "name": "Create Employee",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/api/employees/",
            "body": {
              "mode": "raw",
              "raw": "{\"form\": 1, \"field_values\": [{\"field\": 1, \"value\": \"John Doe\"}, {\"field\": 2, \"value\": \"28\"}]}"
            }
          }
        },
        {
          "name": "Get Employee",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/api/employees/1/"
          }
        },
        {
          "name": "Update Employee",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/api/employees/1/",
            "body": {
              "mode": "raw",
              "raw": "{\"field_values\": [{\"field\": 1, \"value\": \"Jane Doe\"}, {\"field\": 2, \"value\": \"30\"}]}"
            }
          }
        },
        {
          "name": "Delete Employee",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/api/employees/1/"
          }
        }
      ]
    }
  ]
}